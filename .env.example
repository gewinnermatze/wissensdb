WISSENSDB_ENV=production
WISSENSDB_API_HOST=0.0.0.0
WISSENSDB_API_PORT=8080
WISSENSDB_DATABASE_URL=postgresql+psycopg://wissensdb:change-me@postgres:5432/wissensdb
WISSENSDB_EMBEDDING_PROVIDER=hash
WISSENSDB_EMBEDDING_DIMENSION=384

POSTGRES_DB=wissensdb
POSTGRES_USER=wissensdb
POSTGRES_PASSWORD=change-me

# Format: token:agent_id:role,another-token:agent_id:role
# Roles: reader, contributor, maintainer
WISSENSDB_AGENT_TOKENS=agent-token-reader:reader-agent:reader,agent-token-contributor:coding-agent:contributor,agent-token-maintainer:human-maintainer:maintainer

# Optional, only when WISSENSDB_EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
