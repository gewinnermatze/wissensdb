WISSENSDB_ENV=production
WISSENSDB_API_HOST=0.0.0.0
WISSENSDB_API_PORT=8080
WISSENSDB_RUN_MIGRATIONS=true
WISSENSDB_POSTGRES_HOST=postgres
WISSENSDB_POSTGRES_PORT=5432
WISSENSDB_EMBEDDING_PROVIDER=hash
WISSENSDB_EMBEDDING_DIMENSION=768

WISSENSDB_POSTGRES_DB=wissensdb
WISSENSDB_POSTGRES_USER=wissensdb
WISSENSDB_POSTGRES_PASSWORD=change-me

# Format: token:agent_id:role,another-token:agent_id:role
# Roles: reader, contributor, maintainer
WISSENSDB_AGENT_TOKENS=agent-token-reader:reader-agent:reader,agent-token-contributor:coding-agent:contributor,agent-token-maintainer:human-maintainer:maintainer

# Optional, only when WISSENSDB_EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional, only when WISSENSDB_EMBEDDING_PROVIDER=ollama
WISSENSDB_OLLAMA_URL=http://ollama:11434
WISSENSDB_OLLAMA_EMBEDDING_MODEL=nomic-embed-text-v2-moe
